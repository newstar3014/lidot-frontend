function MainOneSlideLoad() {
    $.ajax({
        url: SERVER_AP + "/main/mainbanner-slide-main-one",
        type: "post",
        cache: false,
        data: {},
        success: function(data) {

//             $.each(data, function(i, v) {
//                 var mt = ``;
//                 if (v.b_dateyn == 'Y') {
//                     mt = `<p class="${mt}">${v.b_date}</p>`
